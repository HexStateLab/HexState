{#-
    Mythos Template v1.1
    Gemma 4 26B-A4B — Full Cognitive Architecture
    Built from official spec: ai.google.dev/gemma/docs/core/prompt-formatting-gemma4

    Control Tokens:
      Turns:    <|turn>role ... <turn|>
      Think:    <|think|> (system), <|channel>thought ... <channel|> (content)
      Tools:    <|tool> ... <tool|>, <|tool_call> ... <tool_call|>, <|tool_response> ... <tool_response|>
      Strings:  <|"|>value<|"|>
      Media:    <|image|>, <|audio|>, <|video|>
-#}

{#- ════════════════════════════════════════════════════════════════════
    UTILITY MACROS — Argument & Parameter Serialization
    These format tool declarations into Gemma 4's native structured syntax.
    ════════════════════════════════════════════════════════════════════ -#}

{%- macro serialize_value(val, quote_keys=True) -%}
    {%- if val is string -%}
        {{- '<|"|>' + val + '<|"|>' -}}
    {%- elif val is boolean -%}
        {{- 'true' if val else 'false' -}}
    {%- elif val is mapping -%}
        {{- '{' -}}
        {%- set sep = namespace(need=false) -%}
        {%- for k, v in val | dictsort -%}
            {%- if sep.need %},{% endif -%}
            {%- set sep.need = true -%}
            {%- if quote_keys -%}
                {{- '<|"|>' + k + '<|"|>' -}}
            {%- else -%}
                {{- k -}}
            {%- endif -%}
            :{{- serialize_value(v, quote_keys=quote_keys) -}}
        {%- endfor -%}
        {{- '}' -}}
    {%- elif val is sequence -%}
        {{- '[' -}}
        {%- for item in val -%}
            {{- serialize_value(item, quote_keys=quote_keys) -}}
            {%- if not loop.last %},{% endif -%}
        {%- endfor -%}
        {{- ']' -}}
    {%- else -%}
        {{- val -}}
    {%- endif -%}
{%- endmacro -%}

{%- macro serialize_params(properties, required) -%}
    {%- set skip = ['description', 'type', 'properties', 'required', 'nullable'] -%}
    {%- set sep = namespace(need=false) -%}
    {%- for key, spec in properties | dictsort -%}
        {%- if key not in skip -%}
            {%- if sep.need %},{% endif -%}
            {%- set sep.need = true -%}
            {%- set comma = namespace(need=false) -%}
            {{ key }}:{
            {#- Description -#}
            {%- if spec['description'] -%}
                description:<|"|>{{ spec['description'] }}<|"|>
                {%- set comma.need = true -%}
            {%- endif -%}
            {#- String enums -#}
            {%- if spec['type'] | upper == 'STRING' and spec['enum'] -%}
                {%- if comma.need %},{% endif -%}{%- set comma.need = true -%}
                enum:{{ serialize_value(spec['enum']) }}
            {%- endif -%}
            {#- Array items -#}
            {%- if spec['type'] | upper == 'ARRAY' and spec['items'] is mapping -%}
                {%- if comma.need %},{% endif -%}{%- set comma.need = true -%}
                items:{
                {%- set isep = namespace(need=false) -%}
                {%- for ik, iv in spec['items'] | dictsort -%}
                    {%- if iv is not none -%}
                        {%- if isep.need %},{% endif -%}{%- set isep.need = true -%}
                        {%- if ik == 'properties' and iv is mapping -%}
                            properties:{ {{- serialize_params(iv, spec['items']['required'] | default([])) -}} }
                        {%- elif ik == 'required' -%}
                            required:[
                            {%- for r in iv -%}<|"|>{{ r }}<|"|>{%- if not loop.last %},{% endif -%}{%- endfor -%}
                            ]
                        {%- elif ik == 'type' -%}
                            {%- if iv is string -%}
                                type:{{ serialize_value(iv | upper) }}
                            {%- else -%}
                                type:{{ serialize_value(iv | map('upper') | list) }}
                            {%- endif -%}
                        {%- else -%}
                            {{ ik }}:{{ serialize_value(iv) }}
                        {%- endif -%}
                    {%- endif -%}
                {%- endfor -%}
                }
            {%- endif -%}
            {#- Nullable -#}
            {%- if spec['nullable'] -%}
                {%- if comma.need %},{% endif -%}{%- set comma.need = true -%}
                nullable:true
            {%- endif -%}
            {#- Nested object -#}
            {%- if spec['type'] | upper == 'OBJECT' -%}
                {%- if spec['properties'] is defined and spec['properties'] is mapping -%}
                    {%- if comma.need %},{% endif -%}{%- set comma.need = true -%}
                    properties:{ {{- serialize_params(spec['properties'], spec['required'] | default([])) -}} }
                {%- elif spec is mapping -%}
                    {%- if comma.need %},{% endif -%}{%- set comma.need = true -%}
                    properties:{ {{- serialize_params(spec, spec['required'] | default([])) -}} }
                {%- endif -%}
                {%- if spec['required'] -%}
                    {%- if comma.need %},{% endif -%}{%- set comma.need = true -%}
                    required:[
                    {%- for r in spec['required'] | default([]) -%}<|"|>{{ r }}<|"|>{%- if not loop.last %},{% endif -%}{%- endfor -%}
                    ]
                {%- endif -%}
            {%- endif -%}
            {#- Type (always last) -#}
            {%- if comma.need %},{% endif -%}
            type:<|"|>{{ spec['type'] | upper }}<|"|>}
        {%- endif -%}
    {%- endfor -%}
{%- endmacro -%}

{%- macro serialize_tool(tool) -%}
    {%- set fn = tool['function'] -%}
    declaration:{{ fn['name'] }}{description:<|"|>{{ fn['description'] }}<|"|>
    {%- set p = fn['parameters'] -%}
    {%- if p -%}
        ,parameters:{
        {%- if p['properties'] -%}
            properties:{ {{- serialize_params(p['properties'], p['required']) -}} },
        {%- endif -%}
        {%- if p['required'] -%}
            required:[{%- for r in p['required'] -%}<|"|>{{ r }}<|"|>{{ ',' if not loop.last }}{%- endfor -%}],
        {%- endif -%}
        {%- if p['type'] -%}
            type:<|"|>{{ p['type'] | upper }}<|"|>}
        {%- endif -%}
    {%- endif -%}
    {%- if 'response' in fn -%}
        {%- set resp = fn['response'] -%}
        ,response:{
        {%- if resp['description'] -%}description:<|"|>{{ resp['description'] }}<|"|>,{%- endif -%}
        {%- if resp['type'] | upper == 'OBJECT' -%}type:<|"|>{{ resp['type'] | upper }}<|"|>}{%- endif -%}
    {%- endif -%}
    }
{%- endmacro -%}

{%- macro serialize_tool_response(name, body) -%}
    {{- '<|tool_response>' -}}
    {%- if body is mapping -%}
        {{- 'response:' + name + '{' -}}
        {%- for k, v in body | dictsort -%}
            {{- k }}:{{ serialize_value(v, quote_keys=False) -}}
            {%- if not loop.last %},{% endif -%}
        {%- endfor -%}
        {{- '}' -}}
    {%- else -%}
        {{- 'response:' + name + '{value:' + serialize_value(body, quote_keys=False) + '}' -}}
    {%- endif -%}
    {{- '<tool_response|>' -}}
{%- endmacro -%}

{#- ════════════════════════════════════════════════════════════════════
    THINKING CHANNEL MACROS — Extract, Strip, Preserve
    Manages the thought channel across multi-turn conversations.
    Per Google spec: strip thoughts between standard turns,
    preserve within tool-call turns, keep last 3 chains for context.
    ════════════════════════════════════════════════════════════════════ -#}

{%- macro thought_strip(text) -%}
    {%- set ns = namespace(out='') -%}
    {%- for segment in text.split('<channel|>') -%}
        {%- if '<|channel>' in segment -%}
            {%- set ns.out = ns.out + segment.split('<|channel>')[0] -%}
        {%- else -%}
            {%- set ns.out = ns.out + segment -%}
        {%- endif -%}
    {%- endfor -%}
    {{- ns.out | trim -}}
{%- endmacro -%}

{%- macro thought_extract(text) -%}
    {%- set ns = namespace(out='') -%}
    {%- for segment in text.split('<channel|>') -%}
        {%- if '<|channel>' in segment -%}
            {%- set block = segment.split('<|channel>')[1] -%}
            {%- if block and block.strip().startswith('thought') -%}
                {%- set ns.out = ns.out + block.strip()[7:].strip() + '\n' -%}
            {%- endif -%}
        {%- endif -%}
    {%- endfor -%}
    {{- ns.out | trim -}}
{%- endmacro -%}

{%- macro thought_preserve(text) -%}
    {%- set thoughts = thought_extract(text) -%}
    {%- set clean = thought_strip(text) -%}
    {%- if thoughts -%}
        {{- '<|channel>thought\n' + thoughts + '\n<channel|>' + clean -}}
    {%- else -%}
        {{- clean -}}
    {%- endif -%}
{%- endmacro -%}

{#- ════════════════════════════════════════════════════════════════════
    COGNITIVE PROTOCOL — Mythos Architecture
    Injected into system turn when thinking is enabled.
    Designed for deep reasoning with linear convergence.
    ════════════════════════════════════════════════════════════════════ -#}

{%- macro cognitive_protocol() -%}
{{- '\n\n[COGNITIVE PROTOCOL]\nYour thought channel is your private workspace for deep reasoning. Structure your thinking:\n\n## DECOMPOSE\nIdentify all components of the problem — inputs, constraints, expected outputs, edge cases.\n\n## HYPOTHESIZE\nFormulate your approach. For code: mentally trace execution paths. For logic: state assumptions explicitly. Consider multiple approaches before committing.\n\n## VERIFY\nTest your hypothesis rigorously. Trace through concrete examples. Stress-test edge cases. If you find an error, write "Correction:" and fix it immediately — then continue forward.\n\n## CONCLUDE\nState your verified answer with certainty. Close the thought channel.\n\nDIRECTIVES:\n- Reason with depth and rigor. Challenge your own assumptions.\n- Each reasoning step must advance toward the solution. Do not revisit completed steps.\n- If you discover an error, correct it once and commit to the fix.\n- Your visible response must be structured, precise, and definitive.' -}}
{%- endmacro -%}

{#- ════════════════════════════════════════════════════════════════════
    TEMPLATE BODY — Message Processing Pipeline
    ════════════════════════════════════════════════════════════════════ -#}

{%- set state = namespace(prev_type=None) -%}
{%- set msgs = messages -%}
{{- bos_token -}}

{#- ──────── SYSTEM TURN ──────── -#}
{%- if (enable_thinking is defined and enable_thinking) or tools or msgs[0]['role'] in ['system', 'developer'] -%}
    {{- '<|turn>system\n' -}}
    {#- Thinking activation -#}
    {%- if enable_thinking is defined and enable_thinking -%}
        {{- '<|think|>\n' -}}
        {%- set state.prev_type = 'think' -%}
    {%- endif -%}
    {#- System message content -#}
    {%- if msgs[0]['role'] in ['system', 'developer'] -%}
        {{- msgs[0]['content'] | trim -}}
        {%- set msgs = messages[1:] -%}
    {%- endif -%}
    {#- Inject cognitive protocol -#}
    {%- if enable_thinking is defined and enable_thinking -%}
        {{- cognitive_protocol() -}}
    {%- endif -%}
    {#- Tool declarations -#}
    {%- if tools -%}
        {%- for tool in tools %}
            {{- '<|tool>' -}}
            {{- serialize_tool(tool) | trim -}}
            {{- '<tool|>' -}}
        {%- endfor %}
        {%- set state.prev_type = 'tool' -%}
    {%- endif -%}
    {{- '<turn|>\n' -}}
{%- endif %}

{#- ──────── PRE-SCAN: Locate last user message ──────── -#}
{%- set scan = namespace(last_user=-1) -%}
{%- for i in range(msgs | length) -%}
    {%- if msgs[i]['role'] == 'user' -%}
        {%- set scan.last_user = i -%}
    {%- endif -%}
{%- endfor -%}

{#- ──────── PRE-SCAN: Index thinking chains, cap preservation at 3 ──────── -#}
{%- set chains = namespace(count=0, at=[]) -%}
{%- for i in range(msgs | length) -%}
    {%- if msgs[i]['role'] == 'assistant' -%}
        {%- set hit = namespace(yes=false) -%}
        {%- if msgs[i].get('reasoning') or msgs[i].get('reasoning_content') -%}
            {%- set hit.yes = true -%}
        {%- elif msgs[i].get('content') is string and '<|channel>' in msgs[i]['content'] -%}
            {%- set hit.yes = true -%}
        {%- endif -%}
        {%- if hit.yes -%}
            {%- set chains.count = chains.count + 1 -%}
            {%- set chains.at = chains.at + [i] -%}
        {%- endif -%}
    {%- endif -%}
{%- endfor -%}
{%- if chains.count > 3 -%}
    {%- set keep_from = chains.count - 3 -%}
{%- else -%}
    {%- set keep_from = 0 -%}
{%- endif -%}
{%- set recent = namespace(at=[]) -%}
{%- for idx in range(keep_from, chains.at | length) -%}
    {%- set recent.at = recent.at + [chains.at[idx]] -%}
{%- endfor -%}

{#- ──────── MESSAGE LOOP ──────── -#}
{%- for msg in msgs -%}
    {%- if msg['role'] != 'tool' -%}
    {%- set state.prev_type = None -%}
    {%- set role = 'model' if msg['role'] == 'assistant' else msg['role'] -%}

    {#- Detect model-turn continuation (tool_call → tool_response → continuation) -#}
    {%- set prev = namespace(role=None, found=false) -%}
    {%- if loop.index0 > 0 -%}
        {%- for j in range(loop.index0 - 1, -1, -1) -%}
            {%- if not prev.found and msgs[j]['role'] != 'tool' -%}
                {%- set prev.role = msgs[j]['role'] -%}
                {%- set prev.found = true -%}
            {%- endif -%}
        {%- endfor -%}
    {%- endif -%}
    {%- if not (role == 'model' and prev.role == 'assistant') -%}
        {{- '<|turn>' + role + '\n' }}
    {%- endif -%}

    {#- Reasoning content (structured reasoning field) -#}
    {%- set reasoning = msg.get('reasoning') or msg.get('reasoning_content') -%}
    {%- if reasoning and loop.index0 > scan.last_user -%}
        {{- '<|channel>thought\n' + reasoning + '\n<channel|>' -}}
    {%- endif -%}

    {#- Tool calls -#}
    {%- if msg.get('tool_calls') -%}
        {%- for tc in msg['tool_calls'] -%}
            {%- set fn = tc['function'] -%}
            {{- '<|tool_call>call:' + fn['name'] + '{' -}}
            {%- if fn['arguments'] is mapping -%}
                {%- set sep = namespace(need=false) -%}
                {%- for k, v in fn['arguments'] | dictsort -%}
                    {%- if sep.need %},{% endif -%}{%- set sep.need = true -%}
                    {{- k }}:{{ serialize_value(v, quote_keys=False) -}}
                {%- endfor -%}
            {%- elif fn['arguments'] is string -%}
                {{- fn['arguments'] -}}
            {%- endif -%}
            {{- '}<tool_call|>' -}}
        {%- endfor -%}
        {%- set state.prev_type = 'tool_call' -%}
    {%- endif -%}

    {#- Tool responses -#}
    {%- set tr = namespace(emitted=false) -%}
    {%- if msg.get('tool_responses') -%}
        {#- Gemma-native: tool_responses on assistant message -#}
        {%- for resp in msg['tool_responses'] -%}
            {{- serialize_tool_response(resp['name'] | default('unknown'), resp['response']) -}}
            {%- set tr.emitted = true -%}
            {%- set state.prev_type = 'tool_response' -%}
        {%- endfor -%}
    {%- elif msg.get('tool_calls') -%}
        {#- OpenAI-style: forward-scan for consecutive role:tool messages -#}
        {%- set fscan = namespace(done=false) -%}
        {%- for k in range(loop.index0 + 1, msgs | length) -%}
            {%- if not fscan.done -%}
                {%- if msgs[k]['role'] != 'tool' -%}
                    {%- set fscan.done = true -%}
                {%- else -%}
                    {%- set tmsg = msgs[k] -%}
                    {%- set tname = namespace(val=tmsg.get('name') | default('unknown')) -%}
                    {%- for tc in msg['tool_calls'] -%}
                        {%- if tc.get('id') == tmsg.get('tool_call_id') -%}
                            {%- set tname.val = tc['function']['name'] -%}
                        {%- endif -%}
                    {%- endfor -%}
                    {%- set tbody = tmsg.get('content') -%}
                    {%- if tbody is string -%}
                        {{- serialize_tool_response(tname.val, tbody) -}}
                    {%- elif tbody is sequence and tbody is not string -%}
                        {%- set txt = namespace(s='') -%}
                        {%- for part in tbody -%}
                            {%- if part.get('type') == 'text' -%}
                                {%- set txt.s = txt.s + (part.get('text') | default('')) -%}
                            {%- endif -%}
                        {%- endfor -%}
                        {{- serialize_tool_response(tname.val, txt.s) -}}
                    {%- else -%}
                        {{- serialize_tool_response(tname.val, tbody) -}}
                    {%- endif -%}
                    {%- set tr.emitted = true -%}
                    {%- set state.prev_type = 'tool_response' -%}
                {%- endif -%}
            {%- endif -%}
        {%- endfor -%}
    {%- endif -%}

    {#- Message content — preserve thinking for 3 most recent chains -#}
    {%- if msg.get('content') is string -%}
        {%- if role == 'model' -%}
            {%- if loop.index0 in recent.at -%}
                {{- thought_preserve(msg['content']) -}}
            {%- else -%}
                {{- thought_strip(msg['content']) -}}
            {%- endif -%}
        {%- else -%}
            {{- msg['content'] | trim -}}
        {%- endif -%}
    {%- elif msg.get('content') is sequence -%}
        {%- for item in msg['content'] -%}
            {%- if item['type'] == 'text' -%}
                {%- if role == 'model' -%}
                    {%- if loop.parent.index0 in recent.at -%}
                        {{- thought_preserve(item['text']) -}}
                    {%- else -%}
                        {{- thought_strip(item['text']) -}}
                    {%- endif -%}
                {%- else -%}
                    {{- item['text'] | trim -}}
                {%- endif -%}
            {%- elif item['type'] == 'image' -%}
                {{- '<|image|>' -}}
                {%- set state.prev_type = 'image' -%}
            {%- elif item['type'] == 'audio' -%}
                {{- '<|audio|>' -}}
                {%- set state.prev_type = 'audio' -%}
            {%- elif item['type'] == 'video' -%}
                {{- '<|video|>' -}}
                {%- set state.prev_type = 'video' -%}
            {%- endif -%}
        {%- endfor -%}
    {%- endif -%}

    {#- Turn termination -#}
    {%- if state.prev_type == 'tool_call' and not tr.emitted -%}
        {{- '<|tool_response>' -}}
    {%- elif not (tr.emitted and not msg.get('content')) -%}
        {{- '<turn|>\n' -}}
    {%- endif -%}

    {%- endif -%}
{%- endfor -%}

{#- ──────── GENERATION PROMPT ──────── -#}
{%- if add_generation_prompt -%}
    {%- if state.prev_type != 'tool_response' and state.prev_type != 'tool_call' -%}
        {{- '<|turn>model\n' -}}
        {%- if not enable_thinking | default(false) -%}
            {#- Stabilize: empty thought channel prevents spontaneous reasoning -#}
            {{- '<|channel>thought\n<channel|>' -}}
        {%- else -%}
            {#- Metacognitive primer for multi-turn coherence -#}
            {%- set meta = namespace(has_prior=false, count=0) -%}
            {%- for m in msgs -%}
                {%- if m['role'] == 'assistant' -%}
                    {%- if m.get('reasoning') or m.get('reasoning_content') -%}
                        {%- set meta.has_prior = true -%}
                        {%- set meta.count = meta.count + 1 -%}
                    {%- elif m['content'] is string and '<|channel>' in m['content'] -%}
                        {%- set meta.has_prior = true -%}
                        {%- set meta.count = meta.count + 1 -%}
                    {%- endif -%}
                {%- endif -%}
            {%- endfor -%}
            {%- if meta.has_prior -%}
                {{- '<|channel>thought\n[PRIOR REASONING: ' + meta.count | string + ' chain(s)] Build on verified conclusions. Correct errors directly. Advance toward the solution.\n' -}}
            {%- endif -%}
        {%- endif -%}
    {%- endif -%}
{%- endif -%}
